{
  "name": "ranking-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vite --open'",
    "predev": "convex init && node setup.mjs --once",
    "build": "tsc -b && vite build",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tables:seed": "npm run tables:clean && npx convex run seedActions:seedAll",
    "tables:clean": "for tableName in `npx convex data`; do npx convex import --table $tableName --replace -y --format jsonLines /dev/null; done"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@tanstack/react-router": "^1.169.2",
    "convex": "^1.36.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
